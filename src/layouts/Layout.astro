---
import '@fontsource-variable/plus-jakarta-sans';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  canonical?: string;
  publishDate?: string;
  modifiedDate?: string;
}

const {
  title = 'Zamana, Kurumsal Claude Eğitim ve Danışmanlık',
  description = 'Türkiye\'nin kurumsal Claude eğitim platformu. Bireysel ve kurumsal programlarla şirketinize en değerli kaynağı geri veriyoruz: zamanı.',
  ogImage = '/og/default.png',
  noindex = false,
  canonical,
  publishDate = '2026-04-25',
  modifiedDate = new Date().toISOString().slice(0, 10),
} = Astro.props;

const siteUrl = 'https://zamana.com.tr';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();

const breadcrumbLabels: Record<string, string> = {
  'programlar': 'Programlar',
  'bireysel': 'Bireysel Program',
  'kurumsal': 'Kurumsal Program',
  'karsilastirma': 'Karşılaştırma',
  'hakkinda': 'Hakkında',
  'iletisim': 'İletişim',
  'gizlilik': 'Gizlilik / KVKK',
  'cerezler': 'Çerez Politikası',
  'sss': 'Sık Sorulan Sorular',
};

const pathParts = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems = pathParts.length > 0 ? [
  { name: 'Anasayfa', url: siteUrl },
  ...pathParts.map((part, i) => ({
    name: breadcrumbLabels[part] || part.charAt(0).toUpperCase() + part.slice(1),
    url: `${siteUrl}/${pathParts.slice(0, i + 1).join('/')}`,
  })),
] : null;
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Murat Özsaygılı" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, siteUrl).toString()} />
    <meta property="og:locale" content="tr_TR" />
    <meta property="og:site_name" content="Zamana" />
    <meta property="article:author" content="Murat Özsaygılı" />
    <meta property="article:published_time" content={`${publishDate}T00:00:00+03:00`} />
    <meta property="article:modified_time" content={`${modifiedDate}T00:00:00+03:00`} />
    <meta name="twitter:card" content="summary_large_image" />

    <meta name="theme-color" content="#0f2855" />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'Zamana',
      legalName: 'Zamana Danışmanlık',
      url: siteUrl,
      logo: `${siteUrl}/images/zamana-logo.webp`,
      image: [
        `${siteUrl}/og/default.png`,
        `${siteUrl}/images/zamana-logo.webp`,
      ],
      email: 'info@zamana.com.tr',
      telephone: '+90 530 490 4740',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Yavuz Sultan Selim Bulvarı, Perlavista Residence B Blok D:2',
        addressLocality: 'Beylikdüzü',
        addressRegion: 'İstanbul',
        addressCountry: 'TR',
      },
      founder: { '@type': 'Person', name: 'Murat Özsaygılı' },
      sameAs: [
        'https://www.linkedin.com/in/murat-%C3%B6zsayg%C4%B1l%C4%B1-59790865/',
        'https://x.com/ZamanaClaude',
      ],
    })} />

    {breadcrumbItems && (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbItems.map((item, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: item.name,
          item: item.url,
        })),
      })} />
    )}
  </head>
  <body>
    <a href="#main" class="skip-link">Ana içeriğe geç</a>
    <Header />
    <main id="main"><slot /></main>
    <Footer />

    {!Astro.url.pathname.startsWith('/iletisim') && (
      <a href="/iletisim" class="sticky-cta" id="sticky-cta" aria-label="Görüşme talep et">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        <span>Görüşme Talep Et</span>
      </a>
    )}

    <style is:global>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--c-navy);
        color: var(--c-white);
        padding: 0.5rem 1rem;
        z-index: 100;
        text-decoration: none;
        font-weight: 600;
        border-radius: 0 0 6px 0;
      }
      .skip-link:focus { left: 0; }

      .sticky-cta {
        display: none;
        position: fixed;
        right: 16px;
        bottom: 16px;
        z-index: 60;
        background: linear-gradient(135deg, var(--c-gold) 0%, var(--c-gold-dark) 100%);
        color: var(--c-white);
        padding: 0.75rem 1.1rem;
        border-radius: 999px;
        font-weight: 700;
        font-size: 0.92rem;
        text-decoration: none;
        align-items: center;
        gap: 0.5rem;
        box-shadow: 0 8px 24px rgba(15, 40, 85, 0.25), 0 2px 8px rgba(201, 168, 76, 0.4);
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.25s ease, transform 0.25s ease;
        pointer-events: none;
      }
      .sticky-cta svg {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
      }
      .sticky-cta.is-visible {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }
      .sticky-cta:active {
        transform: translateY(0) scale(0.97);
      }
      @media (max-width: 820px) {
        .sticky-cta { display: inline-flex; }
      }
    </style>

    <script is:inline>
      (() => {
        const cta = document.getElementById('sticky-cta');
        if (!cta) return;
        const onScroll = () => {
          if (window.scrollY > 320) cta.classList.add('is-visible');
          else cta.classList.remove('is-visible');
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      })();
    </script>
  </body>
</html>
