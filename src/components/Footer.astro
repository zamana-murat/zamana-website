---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <div class="col-brand">
      <a href="/" class="brand" aria-label="Zamana ana sayfa">
        <img src="/images/zamana-logo-horizontal.webp" alt="Zamana" width="248" height="82" />
      </a>
      <p class="footer-tag">
        Türkiye'nin kurumsal Claude eğitim platformu.<br>
        Kurumsal eğitim ve danışmanlık.
      </p>
      <ul class="footer-social" aria-label="Sosyal medya hesaplarımız">
        <li>
          <a href="https://www.linkedin.com/in/murat-%C3%B6zsayg%C4%B1l%C4%B1-59790865/" target="_blank" rel="noopener me" aria-label="LinkedIn'de Murat Özsaygılı">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
              <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.95v5.66H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zm1.78 13.02H3.56V9h3.56v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.23 0z"/>
            </svg>
          </a>
        </li>
        <li>
          <a href="https://x.com/ZamanaClaude" target="_blank" rel="noopener me" aria-label="X (Twitter) Zamana hesabı">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
            </svg>
          </a>
        </li>
      </ul>
    </div>

    <div class="col">
      <h4>Programlar</h4>
      <ul>
        <li><a href="/programlar/bireysel">Bireysel Program</a></li>
        <li><a href="/programlar/kurumsal">Kurumsal Program</a></li>
        <li><a href="/programlar/karsilastirma">Karşılaştırma</a></li>
        <li><a href="/sss">Sık Sorulan Sorular</a></li>
      </ul>
    </div>

    <div class="col">
      <h4>Wiki, Türkçe Claude</h4>
      <ul>
        <li><a href="/wiki/">Tüm Wiki</a></li>
        <li><a href="/wiki/temeller/claude-nedir/">Claude Nedir</a></li>
        <li><a href="/wiki/temeller/planlar/">Planlar ve Fiyatlar</a></li>
        <li><a href="/wiki/temeller/ilk-kurulum/">İlk Kurulum</a></li>
        <li><a href="/wiki/temeller/gizlilik-kvkk/">KVKK ve Gizlilik</a></li>
        <li><a href="/hakkinda">Hakkında</a></li>
      </ul>
    </div>

    <div class="col">
      <h4>İletişim</h4>
      <address class="contact-list">
        <ul>
          <li><a href="mailto:info@zamana.com.tr" aria-label="E-posta gönder: info@zamana.com.tr">info@zamana.com.tr</a></li>
          <li><a href="tel:+905304904740" aria-label="Telefonla ara: artı 90 5 30 4 90 47 40">+90 530 490 4740</a></li>
          <li class="addr">Yavuz Sultan Selim Bulvarı,<br>Perlavista Residence B Blok D:2,<br>Beylikdüzü / İstanbul</li>
        </ul>
      </address>
    </div>
  </div>

  <div class="container footer-bottom">
    <span>© {year} Zamana. Tüm hakları saklıdır.</span>
    <nav aria-label="Yasal">
      <a href="/gizlilik">Gizlilik / KVKK</a>
      <a href="/cerezler">Çerez Politikası</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    background: linear-gradient(160deg, var(--c-navy) 0%, var(--c-navy-deep) 100%);
    color: var(--c-text-light);
    padding: var(--s-7) 0 var(--s-4);
    margin-top: var(--s-6);
  }
  .site-footer__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.4fr;
    gap: var(--s-5);
    padding-bottom: var(--s-6);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    margin-bottom: var(--s-3);
  }
  .brand img {
    background: white;
    padding: 10px 14px;
    border-radius: 10px;
    height: 82px;
    width: auto;
    object-fit: contain;
  }
  .footer-tag {
    color: var(--c-text-light-muted);
    font-size: 0.92rem;
    line-height: 1.6;
    margin-bottom: var(--s-3);
  }
  .footer-social {
    display: flex;
    gap: 0.6rem;
    list-style: none;
  }
  .footer-social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    color: var(--c-text-light-muted);
    transition: background var(--t-fast), color var(--t-fast), transform var(--t-fast);
  }
  .footer-social a:hover {
    background: var(--c-gold);
    color: var(--c-navy-deep);
    transform: translateY(-2px);
  }
  .footer-social svg {
    width: 18px;
    height: 18px;
  }
  .col h4 {
    color: var(--c-gold-light);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: var(--s-3);
  }
  .col ul { display: flex; flex-direction: column; gap: 0.55rem; }
  .col a {
    color: var(--c-text-light-muted);
    transition: color var(--t-fast);
    font-size: 0.95rem;
  }
  .col a:hover { color: var(--c-gold-light); }
  .contact-list { font-style: normal; }
  .contact-list .addr {
    color: var(--c-text-light-muted);
    font-size: 0.88rem;
    line-height: 1.6;
    margin-top: var(--s-2);
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--s-4);
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    flex-wrap: wrap;
    gap: var(--s-3);
  }
  .footer-bottom nav { display: flex; gap: var(--s-4); }
  .footer-bottom a {
    color: rgba(255,255,255,0.6);
    transition: color var(--t-fast);
  }
  .footer-bottom a:hover { color: var(--c-gold-light); }

  @media (max-width: 760px) {
    .site-footer__grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .site-footer__grid { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
