---
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href + '/');
};
const links = [
  { href: '/', label: 'Anasayfa' },
  { href: '/programlar', label: 'Programlar' },
  { href: '/hakkinda', label: 'Hakkında' },
  { href: '/sss', label: 'SSS' },
  { href: '/wiki/', label: 'Wiki' },
  { href: '/iletisim', label: 'İletişim' },
];
---

<header class="site-header" id="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand" aria-label="Zamana ana sayfa">
      <img src="/images/zamana-logo-horizontal-400.webp" srcset="/images/zamana-logo-horizontal-400.webp 400w, /images/zamana-logo-horizontal-600.webp 600w" sizes="184px" alt="Zamana" width="184" height="61" class="brand__mark" />
    </a>

    <nav class="nav-desktop" aria-label="Ana menü">
      {links.map(l => (
        <a
          href={l.href}
          class={`nav-link${isActive(l.href) ? ' nav-link--active' : ''}`}
        >{l.label}</a>
      ))}
      <a href="/iletisim" class="btn btn--primary nav-cta">Görüşme Al</a>
    </nav>

    <button class="nav-toggle" id="nav-toggle" aria-label="Menüyü aç" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav class="nav-mobile" id="nav-mobile" aria-label="Mobil menü">
    {links.map(l => (
      <a href={l.href} class={`nav-link${isActive(l.href) ? ' nav-link--active' : ''}`}>{l.label}</a>
    ))}
    <a href="/iletisim" class="btn btn--primary">Görüşme Al</a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--c-white);
    border-bottom: 1px solid var(--c-border);
    box-shadow: 0 1px 4px rgba(15, 40, 85, 0.04);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 76px;
    gap: var(--s-4);
    padding: 0.3rem 0;
  }
  .brand {
    display: inline-flex;
    align-items: center;
  }
  .brand__mark {
    height: 61px;
    width: auto;
    object-fit: contain;
  }
  @media (max-width: 600px) {
    .brand__mark { height: 48px; }
    .site-header__inner { min-height: 64px; }
  }
  .nav-desktop {
    display: flex;
    align-items: center;
    gap: var(--s-4);
  }
  .nav-link {
    font-weight: 500;
    color: var(--c-text);
    padding: 0.4rem 0.2rem;
    position: relative;
    transition: color var(--t-fast);
  }
  .nav-link:hover { color: var(--c-gold-text); }
  .nav-link--active { color: var(--c-gold-text); }
  .nav-link--active::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -4px;
    height: 2px;
    background: var(--c-gold);
    border-radius: 2px;
  }
  .nav-cta {
    margin-left: var(--s-2);
    padding: 0.55rem 1.1rem;
    font-size: 0.92rem;
  }
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    width: 32px;
    padding: 4px;
  }
  .nav-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--c-navy);
    border-radius: 2px;
    transition: transform var(--t-fast), opacity var(--t-fast);
  }
  .nav-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .nav-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .nav-mobile {
    display: none;
    flex-direction: column;
    gap: var(--s-3);
    padding: var(--s-4);
    border-top: 1px solid var(--c-border);
    background: var(--c-white);
  }
  .nav-mobile.is-open { display: flex; }

  @media (max-width: 820px) {
    .nav-desktop { display: none; }
    .nav-toggle { display: flex; }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-mobile');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    toggle.setAttribute('aria-label', open ? 'Menüyü kapat' : 'Menüyü aç');
  });
</script>
