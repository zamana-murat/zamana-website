---
import type { WikiNavItem } from '../data/wiki-nav';

interface Props {
  prev?: WikiNavItem;
  next?: WikiNavItem;
}
const { prev, next } = Astro.props;
---

{(prev || next) && (
  <nav class="wiki-prev-next" aria-label="Bölüm içi gezinme">
    {prev ? (
      <a href={`/wiki/${prev.slug}/`} class="wiki-prev-next__item wiki-prev-next__prev">
        <span class="wiki-prev-next__dir">← Önceki</span>
        <span class="wiki-prev-next__label">{prev.label}</span>
      </a>
    ) : <span></span>}
    {next ? (
      <a href={`/wiki/${next.slug}/`} class="wiki-prev-next__item wiki-prev-next__next">
        <span class="wiki-prev-next__dir">Sonraki →</span>
        <span class="wiki-prev-next__label">{next.label}</span>
      </a>
    ) : <span></span>}
  </nav>
)}

<style>
  .wiki-prev-next {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 3rem 0 1.5rem;
  }
  .wiki-prev-next__item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--c-border);
    border-radius: var(--r-card);
    text-decoration: none;
    color: var(--c-navy);
    background: var(--c-white);
    transition: border-color var(--t-fast), box-shadow var(--t-fast), transform var(--t-fast);
  }
  .wiki-prev-next__item:hover {
    border-color: var(--c-border-gold);
    box-shadow: var(--sh-soft);
    transform: translateY(-1px);
  }
  .wiki-prev-next__next { text-align: right; }
  .wiki-prev-next__dir {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-gold-text);
    font-weight: 700;
  }
  .wiki-prev-next__label {
    font-weight: 600;
    line-height: 1.3;
  }

  @media (max-width: 600px) {
    .wiki-prev-next { grid-template-columns: 1fr; }
    .wiki-prev-next__next { text-align: left; }
  }
</style>
