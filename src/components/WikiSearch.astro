---
// Wiki search — Pagefind tabanlı, lazy-load modal.
// Build sonrası /pagefind/ klasörü dist'e Pagefind tarafından eklenir.
// Sadece kullanıcı search'e tıklayınca veya Ctrl/Cmd+K ile script + CSS yüklenir.
---

<button
  type="button"
  class="wiki-search-trigger"
  id="wiki-search-trigger"
  aria-label="Wiki içinde ara (Ctrl+K)"
  title="Wiki içinde ara (Ctrl+K)"
>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="11" cy="11" r="8"></circle>
    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
  </svg>
</button>

<div class="wiki-search-modal" id="wiki-search-modal" hidden>
  <div class="wiki-search-modal__backdrop" data-close></div>
  <div class="wiki-search-modal__panel" role="dialog" aria-modal="true" aria-label="Wiki arama">
    <div id="wiki-search-ui">
      <div class="wiki-search-fallback" id="wiki-search-fallback">Arama yükleniyor…</div>
    </div>
    <button type="button" class="wiki-search-modal__close" data-close aria-label="Aramayı kapat">Kapat (Esc)</button>
  </div>
</div>

<script is:inline>
  (function () {
    const trigger = document.getElementById('wiki-search-trigger');
    const modal = document.getElementById('wiki-search-modal');
    if (!trigger || !modal) return;

    let initialized = false;
    let pagefindUI = null;

    function loadPagefind() {
      if (initialized) return Promise.resolve();
      initialized = true;

      const css = document.createElement('link');
      css.rel = 'stylesheet';
      css.href = '/pagefind/pagefind-ui.css';
      document.head.appendChild(css);

      return new Promise((resolve) => {
        const script = document.createElement('script');
        script.src = '/pagefind/pagefind-ui.js';
        script.onload = () => {
          const fb = document.getElementById('wiki-search-fallback');
          if (fb) fb.remove();
          // @ts-ignore
          pagefindUI = new window.PagefindUI({
            element: '#wiki-search-ui',
            showSubResults: true,
            showImages: false,
            resetStyles: false,
            translations: {
              placeholder: 'Wiki içinde ara...',
              clear_search: 'Temizle',
              load_more: 'Daha fazla sonuç yükle',
              search_label: 'Wiki içinde ara',
              filters_label: 'Filtreler',
              zero_results: 'Sonuç bulunamadı: [SEARCH_TERM]',
              many_results: '[COUNT] sonuç: [SEARCH_TERM]',
              one_result: '1 sonuç: [SEARCH_TERM]',
              alt_search: 'Sonuç bulunamadı: [SEARCH_TERM]. Şu sorgu için sonuç gösteriliyor: [DIFFERENT_TERM]',
              search_suggestion: 'Sonuç bulunamadı: [SEARCH_TERM]. Şunları deneyin:',
              searching: 'Aranıyor: [SEARCH_TERM]...',
            },
          });
          resolve();
        };
        script.onerror = () => {
          const fb = document.getElementById('wiki-search-fallback');
          if (fb) {
            fb.textContent = 'Arama indexi henüz hazır değil. (Build gerekli — npm run build)';
            fb.classList.add('wiki-search-fallback--error');
          }
          resolve();
        };
        document.head.appendChild(script);
      });
    }

    function openModal() {
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      loadPagefind().then(() => {
        const input = modal.querySelector('.pagefind-ui__search-input');
        if (input) input.focus();
      });
    }

    function closeModal() {
      modal.hidden = true;
      document.body.style.overflow = '';
    }

    trigger.addEventListener('click', openModal);

    modal.addEventListener('click', (e) => {
      if (e.target.hasAttribute('data-close')) closeModal();
    });

    document.addEventListener('keydown', (e) => {
      // Ctrl+K / Cmd+K → open
      if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        if (modal.hidden) openModal();
        else closeModal();
        return;
      }
      // Esc → close
      if (e.key === 'Escape' && !modal.hidden) {
        closeModal();
      }
    });
  })();
</script>

<style>
  /* Tab çubuğundaki diğer tab'larla aynı görsel ritmi koruyan, sadece ikondan
     ibaret bir tetikleyici. margin-left:auto ile sağa yaslanır. */
  .wiki-search-trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-left: 0.5rem;
    padding: 0.85rem 0.85rem;
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    color: var(--c-text-light-muted);
    cursor: pointer;
    transition: color var(--t-fast), border-color var(--t-fast);
    flex-shrink: 0;
  }
  .wiki-search-trigger:hover {
    color: var(--c-gold-light);
  }
  .wiki-search-trigger:focus-visible {
    outline: 2px solid var(--c-gold);
    outline-offset: -2px;
  }

  @media (max-width: 820px) {
    .wiki-search-trigger {
      padding: 0.75rem 0.6rem;
    }
  }

  .wiki-search-fallback {
    padding: 2rem 1rem;
    text-align: center;
    color: var(--c-text-muted);
    font-size: 0.92rem;
  }
  .wiki-search-fallback--error {
    color: #b45309;
  }

  .wiki-search-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 12vh 1rem 1rem;
  }
  .wiki-search-modal[hidden] { display: none; }
  .wiki-search-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 40, 85, 0.55);
    backdrop-filter: blur(4px);
  }
  .wiki-search-modal__panel {
    position: relative;
    width: min(640px, 100%);
    min-height: 180px;
    max-height: 76vh;
    overflow-y: auto;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    padding: 1.25rem 1.25rem 0.75rem;
    display: flex;
    flex-direction: column;
  }
  .wiki-search-modal__close {
    display: block;
    margin: auto auto 0;
    padding: 0.4rem 0.9rem;
    background: transparent;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font: inherit;
    font-size: 0.85rem;
    color: #4b5563;
    cursor: pointer;
  }
  .wiki-search-modal__close:hover {
    background: #f3f4f6;
    color: var(--c-navy);
  }

  /* Pagefind UI marka uyumu — kendi CSS'i yüklendikten sonra üzerine yazıyoruz */
  :global(.pagefind-ui) {
    --pagefind-ui-primary: var(--c-navy);
    --pagefind-ui-text: var(--c-navy);
    --pagefind-ui-background: #fff;
    --pagefind-ui-border: #e5e7eb;
    --pagefind-ui-tag: var(--c-gold);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: inherit;
  }
  :global(.pagefind-ui__result-link) {
    color: var(--c-navy) !important;
  }
  :global(.pagefind-ui__result-link:hover) {
    color: var(--c-gold) !important;
  }
</style>
