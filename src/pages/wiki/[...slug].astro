---
import { getCollection } from 'astro:content';
import WikiLayout from '../../layouts/WikiLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('wiki');
  return entries.map((entry) => {
    // Map entry slug → URL slug:
    //   index               → ''        → /wiki/
    //   temeller/index      → temeller  → /wiki/temeller/
    //   temeller/foo        → temeller/foo → /wiki/temeller/foo/
    let urlSlug = entry.slug;
    if (urlSlug === 'index') urlSlug = '';
    else urlSlug = urlSlug.replace(/\/index$/, '');
    return {
      params: { slug: urlSlug || undefined },
      props: { entry, urlSlug },
    };
  });
}

const { entry, urlSlug } = Astro.props;
const { Content, headings } = await entry.render();
---

<WikiLayout
  slug={urlSlug}
  title={entry.data.title}
  description={entry.data.description}
  tags={entry.data.tags}
  headings={headings}
>
  <Content />
</WikiLayout>
