---
import Layout from '../layouts/Layout.astro';
import ProgramCard from '../components/ProgramCard.astro';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Zamana',
  legalName: 'Zamana Danışmanlık',
  alternateName: 'Zamana Claude Eğitim',
  url: 'https://zamana.com.tr',
  logo: 'https://zamana.com.tr/images/zamana-logo.webp',
  image: 'https://zamana.com.tr/og/index.png',
  description: 'Türkiye\'nin kurumsal Claude eğitim ve danışmanlık platformu. Bireysel ve kurumsal programlarla şirketlere yapay zekayı iş süreçlerine entegre etme rehberliği sunar.',
  foundingDate: '2026-04',
  founder: {
    '@type': 'Person',
    name: 'Murat Özsaygılı',
    url: 'https://zamana.com.tr/hakkinda',
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Yavuz Sultan Selim Bulvarı, Perlavista Residence B Blok D:2',
    addressLocality: 'Beylikdüzü',
    addressRegion: 'İstanbul',
    addressCountry: 'TR',
  },
  contactPoint: [
    {
      '@type': 'ContactPoint',
      contactType: 'customer service',
      telephone: '+90-530-490-4740',
      email: 'info@zamana.com.tr',
      areaServed: 'TR',
      availableLanguage: ['Turkish', 'English'],
    },
    {
      '@type': 'ContactPoint',
      contactType: 'sales',
      telephone: '+90-530-490-4740',
      email: 'murat@zamana.com.tr',
      areaServed: 'TR',
      availableLanguage: ['Turkish'],
    },
  ],
  sameAs: [
    'https://www.linkedin.com/in/murat-%C3%B6zsayg%C4%B1l%C4%B1-59790865/',
    'https://x.com/ZamanaClaude',
  ],
  knowsAbout: [
    'Anthropic Claude',
    'Yapay Zeka Eğitimi',
    'CLAUDE.md',
    'Model Context Protocol',
    'Kurumsal AI Dönüşümü',
    'Prompt Mühendisliği',
    'AI İş Akışı Tasarımı',
  ],
  areaServed: {
    '@type': 'Country',
    name: 'Türkiye',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Zamana Eğitim Programları',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Bireysel Program',
          description: '3 hafta birebir Claude eğitimi + 3 ay sınırsız telefon desteği. CEO, freelancer ve bağımsız profesyoneller için.',
          url: 'https://zamana.com.tr/programlar/bireysel',
        },
        price: '1000',
        priceCurrency: 'USD',
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Kurumsal Program',
          description: '3 aylık şirket içi Claude dönüşümü. 6 çalışan için departman bazlı eğitim, sınırsız telefon desteği, KVKK rehberliği.',
          url: 'https://zamana.com.tr/programlar/kurumsal',
        },
        price: '3000',
        priceCurrency: 'USD',
        priceSpecification: {
          '@type': 'UnitPriceSpecification',
          price: '3000',
          priceCurrency: 'USD',
          unitText: 'MONTH',
          referenceQuantity: {
            '@type': 'QuantitativeValue',
            value: '3',
            unitCode: 'MON',
          },
        },
      },
    ],
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Zamana',
  url: 'https://zamana.com.tr',
  inLanguage: 'tr-TR',
  publisher: {
    '@type': 'Organization',
    name: 'Zamana',
    logo: {
      '@type': 'ImageObject',
      url: 'https://zamana.com.tr/images/zamana-logo.webp',
    },
  },
};
---

<Layout
  title="Zamana, Türkiye'nin Kurumsal Claude Eğitim Platformu"
  description="Claude bir araç. Onu doğru kullanmak bir beceri. Zamana 3 ayda bu beceriyi şirketinize getirir. Bireysel ve kurumsal eğitim programları."
  ogImage="/og/index.png"
>

  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <section class="hero">
    <div class="hero__bg" aria-hidden="true"></div>
    <div class="container hero__inner">
      <span class="eyebrow eyebrow--light">Kurumsal Claude Eğitimi · Türkiye</span>
      <h1 class="hero__title">
        Claude, doğru öğretildiğinde<br>
        şirketinizi <span class="hero__accent">3 ayda dönüştürür.</span>
      </h1>
      <p class="hero__lead">
        Zamana, Türkiye'nin yapay zeka eğitim platformudur. Bireysel profesyonellere ve şirketlere
        Claude'u gerçek işte nasıl kullanacaklarını gösteririz, örnek üzerinden, kendi işiniz üzerinden.
      </p>
      <div class="hero__cta">
        <a href="/programlar" class="btn btn--primary btn--lg">Programları İncele</a>
        <a href="/wiki/" class="btn btn--ghost btn--lg">Ücretsiz Wiki'ye Git</a>
      </div>
      <div class="hero__meta">
        <span><strong>3 ay</strong> tam destek</span>
        <span><strong>30 dakika</strong> telefon kuralı</span>
        <span><strong>Türkçe</strong> içerik ve eğitim</span>
      </div>
    </div>
  </section>

  <section class="trust-strip" aria-label="Güven göstergeleri">
    <div class="container">
      <ul class="trust-list">
        <li>
          <strong>Anthropic Partner</strong>
          <span>Programı kabul edildi (2026)</span>
        </li>
        <li>
          <strong>25+ yıl</strong>
          <span>Teknoloji ve iş danışmanlığı</span>
        </li>
        <li>
          <strong>250+</strong>
          <span>Analiz edilmiş iş modeli</span>
        </li>
        <li>
          <strong>Intel Türkiye</strong>
          <span>7 yıl teknik danışmanlık</span>
        </li>
      </ul>
    </div>
  </section>

  <section class="section founder-mini">
    <div class="container">
      <div class="founder-mini__grid">
        <div class="founder-mini__photo">
          <img
            src="/images/murat-portre.webp"
            alt="Murat Özsaygılı, Zamana kurucusu"
            width="180"
            height="180"
            loading="lazy"
          />
        </div>
        <div class="founder-mini__text">
          <span class="eyebrow">Kurucu</span>
          <h2>Murat Özsaygılı</h2>
          <p class="lead">
            Bilgisayar mühendisi. 25 yıldır teknoloji ve iş danışmanlığında. Intel Türkiye'ye yedi yıl
            danışmanlık verdim, 250'den fazla iş modelini analiz ettim, dış ticaretten kurumsal BT'ye kadar
            farklı sektörlerde çalıştım.
          </p>
          <p>
            Claude'u ciddi şekilde kullanmaya başladığımda gördüm ki Türkiye'de bu aracı iş süreçlerine
            doğru entegre edebilen çok az kişi var. Zamana'yı bu boşluğu kapatmak için kurdum.
          </p>
          <a href="/hakkinda" class="link-arrow">Hakkımda daha fazla <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom: var(--s-6);">
        <span class="eyebrow">Zamana Nedir</span>
        <h2 class="section-title center">Eğitim. Danışmanlık. Sonuç.</h2>
        <p class="lead center">
          Bir kurs satmıyoruz. Ekibinizin Claude'u günlük işine entegre etmesini sağlıyoruz,
          12 hafta içinde, kanıtlanabilir çıktılarla.
        </p>
      </div>

      <div class="grid grid-3">
        <div class="value-card">
          <div class="value-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 L2 7 L12 12 L22 7 Z"/><path d="M2 17 L12 22 L22 17"/><path d="M2 12 L12 17 L22 12"/></svg>
          </div>
          <h3>Eğitim</h3>
          <p>Ekibinize Claude'u bir araç olarak değil, çalışma ortağı olarak kullanmayı öğretiyoruz. CLAUDE.md'den prompt kütüphanesine, MCP'den otomasyona kadar.</p>
        </div>
        <div class="value-card">
          <div class="value-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <h3>Danışmanlık</h3>
          <p>3 ay boyunca telefon hattımız açık. Ekipte tıkanma yaşandığında 30 dakika içinde dönüş alırsınız. Sınırsız soru, sınırsız destek.</p>
        </div>
        <div class="value-card">
          <div class="value-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h3>Sonuç</h3>
          <p>Tek hedefimiz var: 3 ay sonra ekibinizin günlük işinin parçası olmuş bir Claude pratiği. Sertifikasız ders değil, çalışan iş akışı.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt" id="programlar">
    <div class="container">
      <div class="text-center" style="margin-bottom: var(--s-6);">
        <span class="eyebrow">İki Program</span>
        <h2 class="section-title center">Size Uygun Olanı Seçin</h2>
        <p class="lead center">
          Aynı pedagojik DNA. Farklı ölçek. Bireysel profesyoneller için 3 hafta, şirketler için 3 aylık tam dönüşüm.
        </p>
      </div>

      <div class="grid grid-2" style="max-width: 880px; margin: 0 auto;">
        <ProgramCard
          title="Bireysel Program"
          badge="Hızlı Başlangıç"
          price="$1.000"
          duration="3 hafta eğitim + 3 ay destek"
          audience="CEO, freelancer, bağımsız profesyonel veya kendi başına öğrenmek isteyen çalışan."
          features={[
            "3 hafta × 2 saat birebir oturum",
            "Sıfırdan kurulum: Desktop, Cowork, CLAUDE.md",
            "Sizin gerçek işiniz üzerinden çalışıyoruz",
            "3 ay sınırsız telefon desteği",
            "30 dakika cevap garantisi",
            "Gerek görülürse ücretsiz ek ders saati",
          ]}
          ctaHref="/programlar/bireysel"
          ctaText="Bireysel Programı İncele"
        />
        <ProgramCard
          title="Kurumsal Program"
          badge="Tam Dönüşüm"
          price="$3.000"
          priceSuffix="+ KDV / Ay"
          duration=""
          priceSubtext="Minimum 3 aylık eğitim"
          audience="6+ çalışanı olan KOBİ ve orta ölçekli şirketler. AI dönüşümünü ciddiye alanlar."
          features={[
            "Çalışan başı 6 saat eğitim",
            "Departmana özel müfredat (12 rol kapsamı)",
            "Tüm ekip için sınırsız telefon desteği",
            "Şirket içi 6 Claude şampiyonu yetiştirme",
            "Yapay zeka politika ve KVKK rehberliği",
            "Gerek görülürse ücretsiz ek ders saati",
          ]}
          ctaHref="/programlar/kurumsal"
          ctaText="Kurumsal Programı İncele"
          highlighted={true}
        />
      </div>

      <p class="text-center" style="margin-top: var(--s-5);">
        <a href="/programlar/karsilastirma" class="link-arrow">İki programı karşılaştır <span aria-hidden="true">→</span></a>
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom: var(--s-6);">
        <span class="eyebrow">Neden Zamana</span>
        <h2 class="section-title center">Kurs Değil, Pratik</h2>
      </div>

      <div class="grid grid-2 reasons">
        <div class="reason">
          <div class="reason__num">01</div>
          <div>
            <h3>Sizin işinizi öğretiyoruz, demoyu değil</h3>
            <p>İlk oturumdan itibaren <strong>kendi gerçek görevinizi</strong> Claude ile çalışırız. Yazılı senaryo değil, masanızdaki bekleyen iş.</p>
          </div>
        </div>
        <div class="reason">
          <div class="reason__num">02</div>
          <div>
            <h3>Zorluk, öğrenmenin kendisidir</h3>
            <p>Hazır cevap vermeyiz. Birlikte deneriz, hata yaparsınız, düzeltiriz. Üç ay sonra Claude olmadan da düşünebilen bir AI kullanıcısı çıkıyor.</p>
          </div>
        </div>
        <div class="reason">
          <div class="reason__num">03</div>
          <div>
            <h3>Türkiye odaklı, Türkçe ilk</h3>
            <p>İçeriklerimiz, örneklerimiz, müfredatımız Türk iş kültürüne göre tasarlandı. KVKK uyumu, yerel müşteri profili, Türkçe çıktı kalitesi, hepsi temelden ele alınmış.</p>
          </div>
        </div>
        <div class="reason">
          <div class="reason__num">04</div>
          <div>
            <h3>30 dakika telefon kuralı</h3>
            <p>Tıkandığınızda telefonu açın. Yarım saat içinde dönüş garantisi. Çünkü öğrenme oturumda değil, gerçek işte yaşanır.</p>
          </div>
        </div>
        <div class="reason">
          <div class="reason__num">05</div>
          <div>
            <h3>CLAUDE.md ile size özel kurulum</h3>
            <p>Standart asistan değil, sizin asistanınız. Rolünüz, müşteri profiliniz, çalışma tarzınız Claude'un belleğine yazılır, her seferinde sıfırdan anlatmak yok.</p>
          </div>
        </div>
        <div class="reason">
          <div class="reason__num">06</div>
          <div>
            <h3>Hedefimiz bağımsızlığınız</h3>
            <p>Sizi bize bağımlı yapmıyoruz. 3 ay sonra kendi başınıza yeni iş akışları kuran, prompt yazan, ekibini eğitebilen bir Claude kullanıcısısınız.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section mini-faq">
    <div class="container container-narrow">
      <div class="text-center" style="margin-bottom: var(--s-5);">
        <span class="eyebrow">Sıkça Sorulan Sorular</span>
        <h2 class="section-title center">Karar vermeden önce</h2>
        <p class="lead center">
          En sık karşılaştığımız 4 soru. Daha fazlası için <a href="/sss" class="link-inline">SSS sayfasına</a> bakın.
        </p>
      </div>

      <ol class="mini-faq__list">
        <li>
          <details>
            <summary>
              <span class="mfq-q">Bu eğitim için ne kadar Claude bilgisi gerekir?</span>
              <span class="mfq-toggle" aria-hidden="true">+</span>
            </summary>
            <p>
              Sıfır. Hedef kitle Claude'u hiç kullanmamış veya birkaç kez denemiş iş profesyonelleri. CEO, satış, hukuk, finans, İK, operasyon gibi rollerde çalışan, kod yazmayan kişiler. Yazılım veya yapay zeka geçmişi gerekmez.
            </p>
          </details>
        </li>
        <li>
          <details>
            <summary>
              <span class="mfq-q">Fiyat neden bu seviyede? Daha ucuza alabilir miyim?</span>
              <span class="mfq-toggle" aria-hidden="true">+</span>
            </summary>
            <p>
              Zamana online video kurs satmıyor. Birebir, kendi gerçek işiniz üzerinden, üç ay açık telefon hattı olan bir danışman ilişkisi. "Daha ucuz" alternatifler kayıttan dinlenen video kurslar veya generic eğitimler. Aynı iş değil.
            </p>
          </details>
        </li>
        <li>
          <details>
            <summary>
              <span class="mfq-q">Süre neden 3 hafta veya 3 ay? Daha hızlı olamaz mı?</span>
              <span class="mfq-toggle" aria-hidden="true">+</span>
            </summary>
            <p>
              Çünkü öğrenme oturumda değil, oturumlar arasındaki gerçek işte yaşanır. Haftada bir oturum, aralarda öğrendiklerinizi denersiniz, sıradaki oturumda hatalar ve sorular çıkar, oradan ilerleriz. Sıkıştırılırsa kalıcı öğrenme olmuyor.
            </p>
          </details>
        </li>
        <li>
          <details>
            <summary>
              <span class="mfq-q">Üç ay sonra ne olur? Sürekli bağımlı mı kalıyoruz?</span>
              <span class="mfq-toggle" aria-hidden="true">+</span>
            </summary>
            <p>
              Tam tersi, hedefimiz bağımsızlığınız. Üç ay sonunda yeni iş akışı kurabilen, prompt yazabilen, ekibinize öğretebilen bir Claude kullanıcısı oluyorsunuz. İhtiyaç duymuyorsanız Zamana doğru iş yapmıştır.
            </p>
          </details>
        </li>
      </ol>

      <p class="text-center" style="margin-top: var(--s-4);">
        <a href="/sss" class="link-arrow">9 soru daha SSS sayfasında <span aria-hidden="true">→</span></a>
      </p>
    </div>
  </section>

  <section class="section section--dark wiki-cta">
    <div class="container">
      <div class="wiki-cta__grid">
        <div class="wiki-cta__text">
          <span class="eyebrow">Ücretsiz Kaynak</span>
          <h2>Zamana Wiki: Türkçe Claude Bilgi Tabanı</h2>
          <p class="lead">
            Programa başlamadan önce ne öğreneceğinizi merak ediyorsanız wiki'mizi inceleyin.
            Ücretsiz, Türkçe. Claude ile çalışmanın temellerinden 12 departman bazlı kullanım örneklerine kadar geniş bir bilgi tabanı.
          </p>
          <a href="/wiki/" class="btn btn--primary">Wiki'ye Git</a>
        </div>
        <ul class="wiki-cta__list">
          <li><a href="/wiki/temeller/claude-nedir/">Claude nedir, nasıl çalışır</a></li>
          <li><a href="/wiki/temeller/ilk-7-gun/">İlk 7 gün rehberi</a></li>
          <li><a href="/wiki/claude-md/">CLAUDE.md kurulumu</a></li>
          <li><a href="/wiki/prompting/">Prompt yazma sanatı</a></li>
          <li><a href="/wiki/departmanlar/">12 departman için kullanım örnekleri</a></li>
          <li><a href="/wiki/temeller/gizlilik-kvkk/">KVKK ve gizlilik</a></li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section final-cta">
    <div class="container text-center">
      <h2>İlk konuşmayı yapalım.</h2>
      <p class="lead center">
        Ne sattığımızı anlatmadan önce, ne yaptığınızı dinliyoruz.<br>
        15 dakika içinde size uygun olan programı netleştiririz.
      </p>
      <div style="display: inline-flex; gap: var(--s-3); flex-wrap: wrap; justify-content: center; margin-top: var(--s-3);">
        <a href="/iletisim" class="btn btn--primary btn--lg">Görüşme Talep Et</a>
        <a href="mailto:info@zamana.com.tr" class="btn btn--secondary btn--lg">E-posta Gönder</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero {
    position: relative;
    color: var(--c-text-light);
    overflow: hidden;
    padding: clamp(var(--s-7), 12vw, 9rem) 0 clamp(var(--s-7), 10vw, 7rem);
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 18% 20%, rgba(201, 168, 76, 0.18) 0%, transparent 55%),
      radial-gradient(ellipse at 85% 80%, rgba(26, 61, 122, 0.5) 0%, transparent 55%),
      linear-gradient(160deg, var(--c-navy) 0%, var(--c-navy-deep) 100%);
    z-index: -2;
  }
  .hero__bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .hero__inner { position: relative; z-index: 1; max-width: 880px; }
  .eyebrow--light { color: var(--c-gold-light); }
  .hero__title {
    color: var(--c-white);
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: var(--s-3) 0 var(--s-4);
  }
  .hero__accent { color: var(--c-gold-light); }
  .hero__lead {
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: var(--c-text-light-muted);
    line-height: 1.7;
    max-width: 60ch;
    margin-bottom: var(--s-5);
  }
  .hero__cta {
    display: flex;
    gap: var(--s-3);
    flex-wrap: wrap;
    margin-bottom: var(--s-5);
  }
  .hero__meta {
    display: flex;
    gap: var(--s-5);
    flex-wrap: wrap;
    padding-top: var(--s-4);
    border-top: 1px solid rgba(255,255,255,0.1);
    font-size: 0.92rem;
    color: var(--c-text-light-muted);
  }
  .hero__meta strong { color: var(--c-gold-light); font-weight: 700; margin-right: 0.3rem; }

  .trust-strip {
    background: var(--c-bg-subtle);
    border-bottom: 1px solid var(--c-border);
    padding: var(--s-4) 0;
  }
  .trust-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--s-3);
    list-style: none;
  }
  .trust-list li {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 var(--s-2);
  }
  .trust-list strong {
    color: var(--c-navy);
    font-size: 1.05rem;
    font-weight: 800;
