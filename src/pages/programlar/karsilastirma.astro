---
import Layout from '../../layouts/Layout.astro';

const rows = [
  { label: 'Süre',                  bireysel: '3 hafta + 3 ay destek',     kurumsal: 'Minimum 3 ay (aylık devam)' },
  { label: 'Katılımcı sayısı',       bireysel: '1 kişi',                    kurumsal: '6 çalışan' },
  { label: 'Kişi başı eğitim saati', bireysel: '6 saat (3×2)',              kurumsal: '6 saat (2×3)' },
  { label: 'Toplam eğitim saati',    bireysel: '6 saat',                    kurumsal: '36 saat (6 × 6)' },
  { label: 'Telefon desteği',        bireysel: '3 ay sınırsız',             kurumsal: 'Sınırsız (tüm ekip, eğitim süresince)' },
  { label: 'Fiyat',                  bireysel: '$1.000 + KDV (tek seferlik)', kurumsal: '$3.000 + KDV / ay (min. 3 ay)' },
  { label: 'Kişi başı maliyet',      bireysel: '$1.000',                    kurumsal: '$1.500' },
  { label: 'Ek ders',                bireysel: 'Gerek görülürse ücretsiz',  kurumsal: 'Gerek görülürse ücretsiz' },
  { label: 'Hedef alıcı',            bireysel: 'Bireysel profesyonel (B2C)', kurumsal: 'Şirket (B2B)' },
  { label: 'Müfredat odağı',         bireysel: 'Kişisel iş akışı',          kurumsal: 'Departman bazlı + ekip dinamiği' },
  { label: 'Şirket içi yayılım',     bireysel: 'Yok (kişisel)',             kurumsal: '6 çalışan = kritik kütle' },
  { label: 'KVKK / politika',        bireysel: 'Genel rehberlik',           kurumsal: 'Şirket politika dokümanı' },
  { label: 'İlerleme raporu',        bireysel: 'Yok',                       kurumsal: '1. ve 2. ay sunumu' },
];

const recRows = [
  { situation: 'Tek başınıza öğrenmek istiyorsunuz',                 rec: 'Bireysel' },
  { situation: 'CEO\'sunuz, şirkete getirmeden önce kendinize alacaksınız', rec: 'Önce Bireysel, sonra Kurumsal' },
  { situation: 'Şirketiniz kurumsal program almıyor, kendiniz ödüyorsunuz', rec: 'Bireysel' },
  { situation: 'Freelance / bağımsız profesyonel',                   rec: 'Bireysel' },
  { situation: '6+ çalışanı olan şirket, AI dönüşümü istiyor',       rec: 'Kurumsal' },
  { situation: 'Küçük işletme (1-3 kişi)',                            rec: 'Her kilit kişi için Bireysel' },
  { situation: 'Büyük kurumsal şirket (50+ çalışan)',                rec: 'Genişletilmiş Kurumsal (12 çalışan, görüşmede yapı netleşir)' },
  { situation: '"Pazar sabahı evde öğrenmek isterim"',                 rec: 'Bireysel' },
];
---

<Layout
  title="Bireysel mi Kurumsal mı? Program Karşılaştırması | Zamana"
  description="Zamana'nın bireysel ve kurumsal programlarını yan yana karşılaştırın. Süre, fiyat, kapsam, hedef kitle ve hangi durumda hangisinin uygun olduğu."
  ogImage="/og/programlar-karsilastirma.png"
>

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Karşılaştırma</span>
      <h1>Bireysel mi, Kurumsal mı?</h1>
      <p class="lead">
        Aynı pedagojik DNA, farklı ölçek. Aşağıdaki tabloda iki programı yan yana görebilir,
        durumunuza uygun olanı seçebilirsiniz.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cmp-table-wrap">
        <table class="cmp-table">
          <thead>
            <tr>
              <th></th>
              <th>
                <div class="th-card">
                  <span class="th-tag">Bireysel</span>
                  <span class="th-price">$1.000 <em>+ KDV</em></span>
                  <a href="/programlar/bireysel" class="th-link">Detaylar →</a>
                </div>
              </th>
              <th>
                <div class="th-card th-card--gold">
                  <span class="th-tag">Kurumsal</span>
                  <span class="th-price">$3.000 <em>+ KDV / ay</em></span>
                  <a href="/programlar/kurumsal" class="th-link">Detaylar →</a>
                </div>
              </th>
            </tr>
          </thead>
          <tbody>
            {rows.map(r => (
              <tr>
                <th scope="row">{r.label}</th>
                <td>{r.bireysel}</td>
                <td>{r.kurumsal}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container container-narrow">
      <span class="eyebrow">Hangisi Bana Uygun?</span>
      <h2 class="section-title">Durumunuza Göre Öneri</h2>

      <table class="rec-table">
        <thead>
          <tr>
            <th>Durumunuz</th>
            <th>Önerilen</th>
          </tr>
        </thead>
        <tbody>
          {recRows.map(r => (
            <tr>
              <td>{r.situation}</td>
              <td><strong>{r.rec}</strong></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="section final-cta">
    <div class="container text-center">
      <h2>Hâlâ emin değil misiniz?</h2>
      <p class="lead center">
        15 dakikalık keşif görüşmesinde durumunuzu dinleyip size dürüst öneri veriyoruz,
        bazen "şu an hiçbiri uygun değil" deriz.
      </p>
      <div style="display: inline-flex; gap: var(--s-3); flex-wrap: wrap; justify-content: center; margin-top: var(--s-3);">
        <a href="/iletisim" class="btn btn--primary btn--lg">Görüşme Talep Et</a>
        <a href="/sss" class="btn btn--secondary btn--lg">Sık Sorulan Sorulara Bak</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .cmp-table-wrap {
    overflow-x: auto;
    border-radius: var(--r-lg);
    border: 1px solid var(--c-border);
  }
  .cmp-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--c-white);
    min-width: 640px;
  }
  .cmp-table th, .cmp-table td {
    padding: var(--s-3) var(--s-4);
    text-align: left;
    border-bottom: 1px solid var(--c-border);
    vertical-align: top;
  }
  .cmp-table thead th { padding: var(--s-3); border-bottom: 2px solid var(--c-border); }
  .cmp-table tbody th {
    width: 30%;
    color: var(--c-navy);
    font-weight: 600;
    background: var(--c-bg-subtle);
  }
  .cmp-table tbody tr:last-child th,
  .cmp-table tbody tr:last-child td { border-bottom: none; }

  .th-card {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    align-items: flex-start;
    padding: var(--s-2);
  }
  .th-card--gold {
    background: var(--c-bg-subtle);
    border-radius: var(--r-card);
    border: 1px solid var(--c-border-gold);
  }
  .th-tag {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-gold-text);
  }
  .th-price {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--c-navy);
  }
  .th-price em {
    font-size: 0.78rem;
    font-weight: 600;
    font-style: normal;
    color: var(--c-gold-text);
    margin-left: 0.25rem;
    letter-spacing: 0.04em;
  }
  .th-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--c-gold-text);
  }

  .rec-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--r-lg);
    overflow: hidden;
    margin-top: var(--s-4);
  }
  .rec-table th, .rec-table td {
    padding: var(--s-3) var(--s-4);
    text-align: left;
    border-bottom: 1px solid var(--c-border);
  }
  .rec-table thead th {
    background: var(--c-bg-subtle);
    color: var(--c-navy);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .rec-table tbody tr:last-child td { border-bottom: none; }
  .rec-table strong { color: var(--c-gold-text); }

  .final-cta {
    background: var(--c-bg-subtle);
    border-top: 1px solid var(--c-border);
  }
</style>
